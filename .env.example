# 复制为 .env 后按需填写，docker-compose 会自动加载
GATEWAY_PORT=8000

# 生产部署时取消注释，直接拉取 CI 构建好的镜像（免本地构建，配合 docker compose pull && up -d）
# GATEWAY_IMAGE=ghcr.io/aichatfire/sync_gateway:latest

# Nacos 配置中心（留空则仅用 config/gateway.yaml 本地兜底）
NACOS_SERVER=
NACOS_DATA_ID=sync-gateway.yaml
CONFIG_MAX_HISTORY=5

# Provider 密钥
VOLC_SD_BASE_URL=
VOLC_SD_API_KEY=
SEEDANCE_BASE_URL=
SEEDANCE_API_KEY=
KLING_BASE_URL=
KLING_API_KEY=

# Gunicorn 并发参数（留空则按 CPU*2+1 自动计算）
GUNICORN_WORKERS=
GUNICORN_WORKER_CONNECTIONS=1000
GUNICORN_TIMEOUT=150
GUNICORN_LOG_LEVEL=info

# 容器资源限制
GATEWAY_CPU_LIMIT=2
GATEWAY_MEM_LIMIT=1g
GATEWAY_CPU_RESERVE=0.5
GATEWAY_MEM_RESERVE=256m
